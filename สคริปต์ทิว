-- === [Logic] ===
local function fetchAllData(player)
    if not player or not player.Parent then 
        HistoryDetails.Text = "📜 ประวัติ: ไม่พบผู้เล่นนี้แล้ว"
        SongDetails.Text = "🎵 ข้อมูลเพลง: -"
        return 
    end
    lastTargetPlayer = player
    HistoryDetails.Text = string.format("📜 ประวัติ: %s\n• ID: %d\n• อายุ: %d วัน", player.DisplayName, player.UserId, player.AccountAge)
    
    local foundId = nil
    if player.Character then
        for _, obj in pairs(player.Character:GetDescendants()) do
            if obj:IsA("Sound") and obj.Playing and obj.SoundId ~= "" then
                foundId = string.match(obj.SoundId, "%d+")
                break
            end
        end
    end
    
    if foundId then
        currentSongId = foundId
        task.spawn(function()
            local success, info = pcall(function() return MarketplaceService:GetProductInfo(tonumber(foundId)) end)
            if success and info then
                currentSongName = info.Name
                SongDetails.Text = string.format("🎵 เพลง: %s\n• ID: %s\n• ผู้สร้าง: %s", info.Name, foundId, info.Creator.Name)
            else
                currentSongName = "Unknown Song"
                SongDetails.Text = string.format("🎵 เพลง: (ไม่สามารถดึงชื่อได้)\n• ID: %s", foundId)
            end
        end)
    else
        currentSongId = ""
        currentSongName = ""
        SongDetails.Text = "🎵 ไม่พบเพลงที่เปิดอยู่"
    end
end

local function refreshList()
    for _, child in pairs(ScrollingFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        if string.find(string.lower(p.DisplayName), string.lower(SearchBar.Text)) or string.find(string.lower(p.Name), string.lower(SearchBar.Text)) then
            local pBtn = Instance.new("TextButton")
            pBtn.Size = UDim2.new(0.95, 0, 0, 30)
            pBtn.Text = p.DisplayName
            pBtn.TextColor3 = Color3.new(1,1,1)
            pBtn.BackgroundColor3 = Color3.fromRGB(50,50,55)
            pBtn.Parent = ScrollingFrame
            Instance.new("UICorner", pBtn)
            pBtn.MouseButton1Click:Connect(function() fetchAllData(p) end)
        end
    end
end

